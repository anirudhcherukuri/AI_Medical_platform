# =============================================================================
# 6. AUGMENTATION PIPELINES (ALBUMENTATIONS)
# =============================================================================
def get_train_transforms(image_size: int, mean: Tuple[float, float, float],
                          std: Tuple[float, float, float]) -> A.Compose:
    """Build the Albumentations pipeline used for training images.

    Args:
        image_size: Target square image size.
        mean: Per-channel normalization mean (ImageNet).
        std: Per-channel normalization std (ImageNet).

    Returns:
        An Albumentations Compose transform.
    """
    return A.Compose(
        [
            A.Resize(image_size, image_size),
            A.HorizontalFlip(p=0.5),
            A.Rotate(limit=15, border_mode=cv2.BORDER_CONSTANT, p=0.5),
            A.RandomBrightnessContrast(
                brightness_limit=0.2, contrast_limit=0.2, p=0.5
            ),
            A.Normalize(mean=mean, std=std),
            ToTensorV2(),
        ]
    )


def get_eval_transforms(image_size: int, mean: Tuple[float, float, float],
                         std: Tuple[float, float, float]) -> A.Compose:
    """Build the Albumentations pipeline used for validation/test images
    (deterministic — resize + normalize only).

    Args:
        image_size: Target square image size.
        mean: Per-channel normalization mean (ImageNet).
        std: Per-channel normalization std (ImageNet).

    Returns:
        An Albumentations Compose transform.
    """
    return A.Compose(
        [
            A.Resize(image_size, image_size),
            A.Normalize(mean=mean, std=std),
            ToTensorV2(),
        ]
    )


