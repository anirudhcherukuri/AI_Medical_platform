# 9. SANITY CHECK — VISUALIZE A TRAINING BATCH
# =============================================================================
def denormalize(tensor: torch.Tensor, mean: Tuple[float, float, float],
                 std: Tuple[float, float, float]) -> np.ndarray:
    """Convert a normalized CHW tensor back to an HWC uint8 numpy image.

    Args:
        tensor: Normalized image tensor of shape (C, H, W).
        mean: Per-channel normalization mean.
        std: Per-channel normalization std.

    Returns:
        HWC uint8 numpy array in [0, 255].
    """
    image = tensor.clone().cpu().numpy().transpose(1, 2, 0)
    image = image * np.array(std) + np.array(mean)
    image = np.clip(image, 0, 1)
    return (image * 255).astype(np.uint8)


