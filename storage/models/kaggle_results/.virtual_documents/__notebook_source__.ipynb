VALID_EXTENSIONS = (".png", ".jpg", ".jpeg", ".bmp")


def discover_images(data_root: str, included_classes: Tuple[str, ...],
                     excluded_subfolders: Tuple[str, ...]) -> pd.DataFrame:
    """Walk the COVID-19 Radiography Dataset directory tree and build a
    dataframe of (filepath, label) pairs, restricted to the requested
    classes and ignoring mask / opacity subfolders.

    The COVID-19 Radiography Dataset ships one subfolder per class, each of
    which typically contains an "images" folder and a "masks" folder. Only
    the "images" folder is relevant for classification.

    Args:
        data_root: Root directory of the dataset.
        included_classes: Class folder names to keep.
        excluded_subfolders: Folder-name fragments to skip (e.g. masks).

    Returns:
        A dataframe with columns ["filepath", "label"].
    """
    records: List[Dict[str, str]] = []
    root_path = Path(data_root)

    if not root_path.exists():
        raise FileNotFoundError(
            f"Dataset root not found at '{data_root}'. "
            "Please verify the Kaggle dataset is attached to this notebook."
        )

    for class_name in included_classes:
        class_dir = root_path / class_name
        if not class_dir.exists():
            print(f"WARNING: class directory '{class_dir}' does not exist, skipping.")
            continue

        for sub_root, sub_dirs, files in os.walk(class_dir):
            sub_root_lower = os.path.basename(sub_root).lower()
            if any(excl in sub_root_lower for excl in excluded_subfolders):
                continue

            for fname in files:
                if fname.lower().endswith(VALID_EXTENSIONS):
                    records.append(
                        {"filepath": os.path.join(sub_root, fname), "label": class_name}
                    )

    df = pd.DataFrame.from_records(records)
    if df.empty:
        raise RuntimeError(
            "No images discovered. Check dataset path and folder structure."
        )
    return df


