def pip_install(package: str) -> None:
    """Install a python package quietly via pip, ignoring failures caused
    by an already-satisfied requirement.

    Args:
        package: pip requirement string, e.g. "albumentations>=1.4.0".
    """
    subprocess.run(
        [sys.executable, "-m", "pip", "install", "-q", package],
        check=False,
    )


